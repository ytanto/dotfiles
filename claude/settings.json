{
  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Edit",
      "Write",
      "Read",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(lsof *)",
      "Bash(time *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(docker-compose *)",
      "Bash(git mv *)",
      "Bash(git --no-pager *)",
      "Bash(git rev-parse *)",
      "Bash(git fetch:*)",
      "Bash(git symbolic-ref:*)",
      "Bash(git diff *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh api *)",
      "Bash(gh api graphql *)",
      "Bash(gh pr checks *)",
      "Bash(gh run view *)",
      "Bash(gh issue create *)",
      "Bash(gh issue *)",
      "Bash(/usr/bin/make *)",
      "Bash(TARGET=app/ *)",
      "Bash(npx tsc*)",
      "WebFetch(domain:firebase.google.com)",
      "WebFetch(domain:docs.cloud.google.com)",
      "WebFetch(domain:github.com)",
      "mcp__serena__*",
      "mcp__chrome-devtools__*",
      "mcp__ide__getDiagnostics",
      "mcp__plugin_figma_figma__*",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "mcp__plugin_playwright_playwright__browser_wait_for",
      "mcp__plugin_playwright_playwright__browser_snapshot",
      "mcp__plugin_playwright_playwright__browser_fill_form",
      "mcp__plugin_playwright_playwright__browser_click",
      "mcp__plugin_playwright_playwright__browser_run_code",
      "mcp__plugin_playwright_playwright__browser_console_messages",
      "Bash(playwright-cli *)",
      "Bash(playwright-cli:*)",
      "mcp__context7__*"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(**/*private*key*)",
      "Read(**/*secret*key*)",
      "Read(**/*.key)",
      "Read(**/*access*key*)",
      "Read(**/*google-service-account-key*)",
      "Write(.env*)",
      "Write(**/secrets/**)",
      "Bash(psql:*)",
      "Bash(mysql:*)"
    ],
    "ask": ["Bash(git push *)"],
    "defaultMode": "auto"
  },
  "model": "claude-opus-4-8",
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "expo-app-design@expo-plugins": true,
    "upgrading-expo@expo-plugins": true,
    "expo-deployment@expo-plugins": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright-cli@playwright-cli": true,
    "ruby-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "crosslog@crosslog-plugins": true
  },
  "extraKnownMarketplaces": {
    "crosslog-plugins": {
      "source": {
        "source": "github",
        "repo": "crossloglife/claude-plugins"
      }
    }
  },
  "language": "japanese",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "autoUpdates": true
}
